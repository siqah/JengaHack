# ============================================================
# ChainSure SaaS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- Blockchain -----
PRIVATE_KEY=your_deployer_private_key_here
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# ----- Deployed Contracts (populated after deployment) -----
FACTORY_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ----- WhatsApp Business API -----
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# ----- Coinbase -----
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base-sepolia

# ----- API -----
API_SECRET_KEY=your_api_secret_key_for_dashboard_auth
FLASK_ENV=development
