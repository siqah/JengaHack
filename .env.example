# ── ChainSure Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values

# ── Deployer / Admin ────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=            # Private key for deploying contracts (no 0x prefix)

# ── Base Network RPC ────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ── USDC Contract Addresses ────────────────────────────────────────
USDC_ADDRESS_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── Seeding ─────────────────────────────────────────────────────────
SEED_AMOUNT=10000               # USDC amount to seed into LiquidityPool

# ── Coinbase ────────────────────────────────────────────────────────
COINBASE_API_KEY=                # Coinbase Developer Platform API key
COINBASE_API_SECRET=             # Coinbase API secret
COINBASE_PAYMASTER_URL=          # Coinbase Paymaster RPC endpoint

# ── WhatsApp (Meta Cloud API) ──────────────────────────────────────
WHATSAPP_API_TOKEN=              # Meta WhatsApp Business API token
WHATSAPP_PHONE_NUMBER_ID=        # WhatsApp Business phone number ID
WHATSAPP_VERIFY_TOKEN=           # Webhook verify token

# ── OpenClaw / AI ──────────────────────────────────────────────────
OPENCLAW_API_KEY=                # OpenClaw agent API key
